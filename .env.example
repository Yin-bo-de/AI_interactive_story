# 幻境回响 - 环境变量配置模板

# 服务器配置
HOST=0.0.0.0
PORT=8000

# AI模型配置
# 支持的模型提供商: openai, anthropic, zhipuai, deepseek
AI_MODEL_PROVIDER=openai
AI_MODEL_NAME=gpt-4o
AI_API_KEY=your_api_key_here
AI_API_BASE=https://api.openai.com/v1

# 游戏配置
MAX_ROUNDS=100
GAME_DURATION=1800  # 游戏时长（秒），30分钟

# 日志配置
LOG_LEVEL=INFO
LOG_DIR=log
